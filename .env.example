# Local development
# The Vite dev server proxies /api and /health to this target.
VITE_API_TARGET=http://localhost:4000

# Production (set this in Vercel -> Settings -> Environment Variables)
# Full URL to the deployed backend API, INCLUDING the /api suffix, e.g.
#   https://your-backend.up.railway.app/api
# Leave empty for local dev (the app falls back to the /api proxy above).
VITE_API_BASE_URL=
